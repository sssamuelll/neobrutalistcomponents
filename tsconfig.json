{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,

    // ============================== 
    //     ACTIVA ESTOS JODIDOS FLAGS
    // ==============================
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // ==============================
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": false,
    "outDir": "dist",
    // Mantén JSX para que Vite lo procese
    "jsx": "react-jsx",

    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  // Incluye la librería y el setup de tests (el setup aporta augmentaciones
  // de tipo de jest-dom/vitest-axe que los tests en src/lib/**/*.test.tsx necesitan).
  "include": ["src/lib", "src/test-setup.ts"],
  // Excluye lo que no pertenece al build de la librería.
  "exclude": ["node_modules", "dist", "src/App.tsx", "src/main.tsx"]
}
