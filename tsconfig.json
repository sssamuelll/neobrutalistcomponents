{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,

    // ============================== 
    //     ACTIVA ESTOS JODIDOS FLAGS
    // ==============================
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // ==============================
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": false,
    "outDir": "dist",
    // Mantén JSX para que Vite lo procese
    "jsx": "react-jsx",

    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  // Incluye **SÓLO** la carpeta de tu librería
  "include": ["src/lib"],
  // Excluye resto de mierda que no necesitas
  "exclude": ["node_modules", "dist", "src/App.tsx", "src/main.tsx"]
}
